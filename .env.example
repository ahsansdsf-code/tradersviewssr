PORT=5177
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/tradersview_pkr

# Required. Use a long random value in production.
JWT_SECRET=change-this-long-random-secret
JWT_EXPIRES_IN=7d
MAX_UPLOAD_MB=5

# First admin account seed values.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@tradersview.pk
ADMIN_PASSWORD=change-this-admin-password

# Local demo user seed values.
DEMO_USERNAME=demo
DEMO_EMAIL=demo@tradersview.pk
DEMO_PASSWORD=123456
DEMO_BALANCE=100000

# Trading and price fallback settings. PKR only.
TRADE_PROFIT_RATE=0.8
PKR_USD_RATE=278

# Optional email notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional SMS provider placeholder.
SMS_PROVIDER_URL=
SMS_PROVIDER_KEY=

# Optional Firebase placeholder.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional OAuth placeholders for social-login settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Optional automatic gateway placeholders.
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
BANK_DEPOSIT_ACCOUNT_TITLE=
BANK_DEPOSIT_ACCOUNT_NUMBER=
